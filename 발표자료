<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>동래에서 부산으로 — 이무현</title>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;600;700&family=Noto+Sans+KR:wght@300;400;500&display=swap" rel="stylesheet">

  <script type="text/javascript" src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js"></script>

  <style>
    :root {
      --sea-deep: #185a73;
      --sea-main: #2c86a5;
      --sea-soft: #63c3dc;
      --sea-mist: #dff5fb;
      --foam: #f8fdff;
      --sand: #f8efe2;
      --shell: #fffaf3;
      --coral: #ff9773;
      --coral-soft: #ffc7b4;
      --sun: #ffe2b0;
      --text: #17495b;
      --muted: #5a7e8e;
      --border: rgba(56, 145, 174, 0.18);
      --shadow: 0 20px 48px rgba(36, 115, 140, 0.12);
      --shadow-soft: 0 12px 32px rgba(75, 150, 174, 0.1);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Noto Sans KR', sans-serif;
      background:
        radial-gradient(circle at top left, rgba(255, 226, 176, 0.55), transparent 28%),
        radial-gradient(circle at right 20%, rgba(99, 195, 220, 0.18), transparent 22%),
        linear-gradient(180deg, #f7fdff 0%, #fffaf4 45%, #f2fbff 100%);
      color: var(--text);
      line-height: 1.7;
      overflow-x: hidden;
      position: relative;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background: url('busan-sea-assets/wave-texture.png') center top / cover no-repeat;
      opacity: 0.14;
      pointer-events: none;
      z-index: -2;
    }

    body::after {
      content: "";
      position: fixed;
      inset: auto -10vw -12rem auto;
      width: 28rem;
      height: 28rem;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 199, 180, 0.32), rgba(255, 199, 180, 0));
      filter: blur(18px);
      pointer-events: none;
      z-index: -1;
    }

    a { color: inherit; }

    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: rgba(248, 253, 255, 0.8);
      border-bottom: 1px solid rgba(44, 134, 165, 0.16);
      backdrop-filter: blur(16px);
      padding: 0 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
      box-shadow: 0 10px 35px rgba(123, 182, 198, 0.08);
    }

    .nav-brand {
      font-family: 'Noto Serif KR', serif;
      color: var(--sea-deep);
      font-size: 0.95rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-decoration: none;
    }

    .nav-links { display: flex; gap: 0.35rem; }

    .nav-links a {
      color: rgba(23, 73, 91, 0.72);
      text-decoration: none;
      font-size: 0.8rem;
      padding: 0 1rem;
      height: 42px;
      display: flex;
      align-items: center;
      border-radius: 999px;
      transition: color 0.2s ease, background 0.2s ease, transform 0.2s ease;
      letter-spacing: 0.03em;
    }

    .nav-links a:hover {
      color: var(--sea-deep);
      background: rgba(99, 195, 220, 0.16);
      transform: translateY(-1px);
    }

    #hero {
      min-height: 100vh;
      background:
        linear-gradient(180deg, rgba(248, 253, 255, 0.16), rgba(248, 253, 255, 0.65)),
        url('busan-sea-assets/hero-busan-sea.png') center/cover no-repeat;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 8rem 2rem 4.5rem;
      color: var(--sea-deep);
      position: relative;
      overflow: hidden;
    }

    #hero::before {
      content: "";
      position: absolute;
      inset: auto 0 -4rem 0;
      height: 18rem;
      background:
        linear-gradient(180deg, rgba(248, 253, 255, 0), rgba(248, 253, 255, 0.7)),
        url('busan-sea-assets/wave-texture.png') center bottom / cover no-repeat;
      opacity: 0.48;
      pointer-events: none;
    }

    #hero > * {
      position: relative;
      z-index: 1;
    }

    .hero-tag {
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--sea-deep);
      border: 1px solid rgba(44, 134, 165, 0.28);
      background: rgba(248, 253, 255, 0.62);
      padding: 0.45rem 1.15rem;
      border-radius: 999px;
      margin-bottom: 2rem;
      box-shadow: 0 10px 24px rgba(82, 154, 179, 0.12);
    }

    #hero h1 {
      font-family: 'Noto Serif KR', serif;
      font-size: clamp(2.2rem, 5vw, 4.15rem);
      font-weight: 700;
      line-height: 1.25;
      margin-bottom: 1.1rem;
      max-width: 780px;
      text-shadow: 0 10px 24px rgba(255, 255, 255, 0.65);
    }

    #hero p.sub {
      font-size: 1.08rem;
      color: rgba(23, 73, 91, 0.78);
      margin-bottom: 2.4rem;
      max-width: 600px;
    }

    .meta-row {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
      font-size: 0.82rem;
      color: rgba(23, 73, 91, 0.84);
      margin-bottom: 2.8rem;
    }

    .meta-row span {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.55rem 1rem;
      background: rgba(248, 253, 255, 0.7);
      border: 1px solid rgba(44, 134, 165, 0.14);
      border-radius: 999px;
      box-shadow: 0 10px 24px rgba(82, 154, 179, 0.08);
    }

    .ch-nav {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      justify-content: center;
      margin-bottom: 2rem;
    }

    .ch-btn {
      padding: 0.72rem 1.55rem;
      border: 1px solid rgba(44, 134, 165, 0.24);
      background: rgba(248, 253, 255, 0.76);
      color: var(--sea-deep);
      text-decoration: none;
      font-size: 0.8rem;
      letter-spacing: 0.06em;
      transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
      border-radius: 999px;
      box-shadow: 0 12px 26px rgba(82, 154, 179, 0.1);
    }

    .ch-btn:hover {
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(223, 245, 251, 0.95));
      transform: translateY(-2px);
      box-shadow: 0 16px 30px rgba(82, 154, 179, 0.16);
    }

    .scroll-hint {
      font-size: 0.72rem;
      color: rgba(23, 73, 91, 0.5);
      letter-spacing: 0.16em;
    }

    .arrow-down {
      animation: bounce 2s infinite;
      display: block;
      margin-top: 0.55rem;
      font-size: 1.2rem;
      color: var(--coral);
    }

    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(8px); }
    }

    section {
      padding: 6.3rem 2rem;
      position: relative;
      isolation: isolate;
    }

    section::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0));
      z-index: -1;
      pointer-events: none;
    }

    .inner {
      max-width: 1080px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    .ch-label {
      display: inline-block;
      font-size: 0.68rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--coral);
      border-bottom: 1px solid rgba(255, 151, 115, 0.7);
      padding-bottom: 0.2rem;
      margin-bottom: 1rem;
      font-weight: 600;
    }

    .section-title {
      font-family: 'Noto Serif KR', serif;
      font-size: clamp(1.6rem, 3vw, 2.3rem);
      font-weight: 700;
      color: var(--sea-deep);
      margin-bottom: 0.6rem;
    }

    .section-desc {
      font-size: 0.96rem;
      color: var(--muted);
      max-width: 610px;
      margin-bottom: 3rem;
    }

    .gold-line {
      width: 3.4rem;
      height: 3px;
      background: linear-gradient(90deg, var(--coral), rgba(255, 151, 115, 0));
      margin-bottom: 3rem;
      border-radius: 999px;
    }

    #intro {
      background:
        linear-gradient(180deg, rgba(222, 245, 251, 0.65), rgba(255, 250, 243, 0.8)),
        url('busan-sea-assets/wave-texture.png') center/cover no-repeat;
    }

    .intro-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 1.5rem;
    }

    .intro-card {
      border: 1px solid var(--border);
      padding: 2rem 1.6rem;
      border-radius: 28px;
      background: rgba(255, 255, 255, 0.78);
      box-shadow: var(--shadow-soft);
      backdrop-filter: blur(12px);
    }

    .intro-card .num {
      font-family: 'Noto Serif KR', serif;
      font-size: 2.5rem;
      color: rgba(44, 134, 165, 0.24);
      font-weight: 700;
      margin-bottom: 0.8rem;
    }

    .intro-card h4 {
      font-size: 0.92rem;
      color: var(--sea-main);
      margin-bottom: 0.6rem;
    }

    .intro-card p {
      font-size: 0.86rem;
      color: var(--muted);
      line-height: 1.75;
    }

    .insight-box {
      margin-top: 3rem;
      border: 1px solid rgba(255, 151, 115, 0.22);
      border-left: 4px solid var(--coral);
      padding: 1.7rem 2rem;
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.78), rgba(255, 244, 238, 0.9));
      border-radius: 24px;
      box-shadow: var(--shadow-soft);
    }

    .insight-box p {
      font-size: 1.05rem;
      color: var(--sea-deep);
      font-style: italic;
    }

    .insight-box cite {
      font-size: 0.79rem;
      color: var(--coral);
      display: block;
      margin-top: 0.7rem;
    }

    .ch04-bridge {
      margin: 2.2rem 0 2.6rem;
    }

    #ch04 .ch04-bridge .insight-box {
      margin-top: 0;
    }

    #ch01 { background: rgba(255, 255, 255, 0.38); }

    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: start;
    }

    .wiki-link-card {
      border: 1px solid var(--border);
      padding: 2rem;
      border-radius: 30px;
      background: rgba(255, 255, 255, 0.86);
      text-decoration: none;
      display: block;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      margin-bottom: 1.5rem;
      box-shadow: var(--shadow-soft);
    }

    .wiki-link-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow);
    }

    .wiki-link-card .wl-tag {
      font-size: 0.68rem;
      color: var(--muted);
      letter-spacing: 0.1em;
      margin-bottom: 0.5rem;
    }

    .wiki-link-card h4 {
      font-family: 'Noto Serif KR', serif;
      font-size: 1.12rem;
      color: var(--sea-deep);
      margin-bottom: 0.4rem;
    }

    .wiki-link-card p {
      font-size: 0.83rem;
      color: var(--muted);
    }

    .wiki-link-card .arrow {
      color: var(--coral);
      font-size: 0.8rem;
      margin-top: 0.8rem;
      display: block;
    }

    .subheading {
      font-size: 0.86rem;
      color: var(--sea-deep);
      font-weight: 700;
      margin-bottom: 1rem;
    }

    .ontology-list { list-style: none; }

    .ontology-list li {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.82rem 0;
      border-bottom: 1px solid rgba(56, 145, 174, 0.12);
      font-size: 0.86rem;
    }

    .ontology-list .tag {
      background: rgba(44, 134, 165, 0.1);
      color: var(--sea-deep);
      font-size: 0.69rem;
      padding: 0.25rem 0.65rem;
      border-radius: 999px;
      border: 1px solid rgba(44, 134, 165, 0.15);
    }

    .graph-wrap {
      border: 1px solid var(--border);
      border-radius: 32px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.82);
      position: relative;
      box-shadow: var(--shadow);
    }

    #mynetwork {
      width: 100%;
      height: 350px;
      background:
        radial-gradient(circle at top, rgba(248, 253, 255, 0.85), rgba(223, 245, 251, 0.95)),
        url('busan-sea-assets/wave-texture.png') center/cover no-repeat;
    }

    .graph-caption {
      padding: 0.95rem 1rem;
      font-size: 0.77rem;
      color: var(--muted);
      background: rgba(248, 253, 255, 0.92);
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 0.75rem;
      border-top: 1px solid rgba(56, 145, 174, 0.12);
    }

    .ghost-inline-link {
      color: var(--sea-deep);
      font-size: 0.74rem;
      text-decoration: none;
      white-space: nowrap;
      border: 1px solid rgba(44, 134, 165, 0.18);
      background: rgba(255, 255, 255, 0.8);
      padding: 0.35rem 0.75rem;
      border-radius: 999px;
      transition: background 0.2s ease, transform 0.2s ease;
    }

    .ghost-inline-link:hover {
      background: rgba(223, 245, 251, 0.9);
      transform: translateY(-1px);
    }

    .lst-box {
      margin-top: 1rem;
      padding: 1rem 1.1rem;
      background: rgba(255, 255, 255, 0.84);
      border: 1px solid var(--border);
      border-radius: 22px;
      font-size: 0.79rem;
      color: var(--muted);
      box-shadow: var(--shadow-soft);
    }

    .lst-box strong {
      color: var(--sea-deep);
      display: block;
      margin-bottom: 0.45rem;
    }

    #ch02 {
      background:
        linear-gradient(180deg, rgba(255, 250, 243, 0.82), rgba(223, 245, 251, 0.42));
    }

    .bigkinds-box {
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.8), rgba(223, 245, 251, 0.78)),
        url('busan-sea-assets/wave-texture.png') center/cover no-repeat;
      padding: 2.6rem;
      border-radius: 34px;
      margin-bottom: 3rem;
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 2rem;
      align-items: center;
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
    }

    .bk-left h4 {
      font-family: 'Noto Serif KR', serif;
      font-size: 1.22rem;
      color: var(--sea-deep);
      margin-bottom: 0.5rem;
    }

    .bk-left p {
      font-size: 0.84rem;
      color: var(--muted);
    }

    .bk-left a.bk-link {
      display: inline-block;
      margin-top: 1rem;
      padding: 0.58rem 1.25rem;
      border: 1px solid rgba(44, 134, 165, 0.22);
      background: rgba(255, 255, 255, 0.78);
      color: var(--sea-deep);
      text-decoration: none;
      font-size: 0.79rem;
      border-radius: 999px;
      transition: background 0.2s ease, transform 0.2s ease;
    }

    .bk-left a.bk-link:hover {
      background: rgba(223, 245, 251, 0.9);
      transform: translateY(-1px);
    }

    .bk-findings {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .bk-finding {
      display: flex;
      gap: 1rem;
      align-items: flex-start;
      padding: 1rem 1.1rem;
      border: 1px solid rgba(56, 145, 174, 0.12);
      border-radius: 22px;
      background: rgba(255, 255, 255, 0.66);
      box-shadow: 0 10px 20px rgba(82, 154, 179, 0.08);
    }

    .bk-num {
      font-size: 1.45rem;
      font-weight: 700;
      color: rgba(44, 134, 165, 0.34);
      min-width: 2rem;
    }

    .bk-text h5 {
      font-size: 0.83rem;
      color: var(--sea-main);
      margin-bottom: 0.3rem;
    }

    .bk-text p {
      font-size: 0.79rem;
      color: var(--muted);
    }

    .timeline-section h3 {
      font-family: 'Noto Serif KR', serif;
      font-size: 1.1rem;
      color: var(--sea-deep);
      margin-bottom: 1rem;
    }

    .timeline-wrap {
      border: 1px solid var(--border);
      border-radius: 30px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.92);
      box-shadow: var(--shadow);
    }

    .timeline-wrap iframe {
      display: block;
      width: 100%;
      height: 650px;
      border: none;
      background: #fff;
    }

    #ch03 {
      background:
        linear-gradient(180deg, rgba(236, 250, 254, 0.96), rgba(255, 250, 244, 0.9)),
        url('busan-sea-assets/wave-texture.png') center/cover no-repeat;
    }

    .content-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .content-block {
      background: rgba(255, 255, 255, 0.78);
      border: 1px solid var(--border);
      border-radius: 30px;
      overflow: hidden;
      box-shadow: var(--shadow);
      backdrop-filter: blur(12px);
    }

    .content-block-header {
      padding: 1.3rem 1.5rem;
      border-bottom: 1px solid rgba(56, 145, 174, 0.12);
      background: linear-gradient(180deg, rgba(248, 253, 255, 0.92), rgba(240, 251, 255, 0.88));
    }

    .content-block-header .cb-tag {
      font-size: 0.66rem;
      letter-spacing: 0.15em;
      color: var(--coral);
      margin-bottom: 0.35rem;
      font-weight: 600;
    }

    .content-block-header h4 {
      font-size: 0.96rem;
      color: var(--sea-deep);
    }

    .slide-embed { padding: 1.5rem; }

    .media-stack {
      padding: 1.15rem;
      background: linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(248, 253, 255, 0.92));
    }

    .slide-scroll-panel {
      height: min(88vh, 980px);
      overflow-y: scroll;
      overflow-x: hidden;
      padding: 0.45rem 0.8rem 0.45rem 0.35rem;
      display: block;
      scroll-snap-type: y proximity;
      overscroll-behavior: contain;
      scrollbar-width: auto;
      scrollbar-color: rgba(44, 134, 165, 0.56) rgba(255, 255, 255, 0.65);
    }

    .slide-scroll-panel::-webkit-scrollbar {
      width: 12px;
    }

    .slide-scroll-panel::-webkit-scrollbar-track {
      background: rgba(255, 255, 255, 0.72);
      border-radius: 999px;
    }

    .slide-scroll-panel::-webkit-scrollbar-thumb {
      background: rgba(44, 134, 165, 0.56);
      border-radius: 999px;
      border: 2px solid rgba(255, 255, 255, 0.72);
    }

    .slide-shot {
      position: relative;
      display: block;
      margin: 0 0 1rem;
      flex-shrink: 0;
      scroll-snap-align: start;
      border-radius: 10px;
      overflow: hidden;
      border: 1px solid rgba(56, 145, 174, 0.14);
      background: rgba(255, 255, 255, 0.94);
      box-shadow: 0 14px 30px rgba(71, 143, 168, 0.12);
    }

    .slide-shot:last-child {
      margin-bottom: 0;
    }

    .slide-shot img {
      display: block;
      width: 100%;
      height: auto;
      object-fit: contain;
      background: #f6fbfd;
    }

    .slide-shot figcaption {
      display: none;
    }

    .slide-link {
      display: block;
      margin-top: 1rem;
      text-align: center;
      padding: 0.75rem;
      border: 1px solid rgba(44, 134, 165, 0.18);
      background: rgba(255, 255, 255, 0.82);
      color: var(--sea-deep);
      text-decoration: none;
      font-size: 0.8rem;
      border-radius: 999px;
      transition: transform 0.2s ease, background 0.2s ease;
    }

    .slide-link:hover {
      background: rgba(223, 245, 251, 0.9);
      transform: translateY(-1px);
    }

    .video-embed {
      padding: 1.6rem;
      display: flex;
      justify-content: center;
    }

    .video-wrapper {
      position: relative;
      width: 100%;
      max-width: 315px;
      margin: 0 auto;
      padding-bottom: 177.78%;
      height: 0;
      overflow: hidden;
      border-radius: 24px;
      box-shadow: 0 18px 40px rgba(71, 143, 168, 0.18);
      border: 6px solid rgba(248, 253, 255, 0.7);
      background: rgba(255, 255, 255, 0.7);
    }

    .video-wrapper iframe {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border: 0;
    }

    .video-origin {
      text-align: center;
      padding-bottom: 1.5rem;
    }

    .video-origin a {
      font-size: 0.76rem;
      color: var(--sea-main);
      text-decoration: none;
    }

    #ch04 { background: rgba(255, 255, 255, 0.32); }

    .insight-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
      margin-bottom: 3rem;
    }

    .insight-card {
      background: rgba(255, 255, 255, 0.84);
      border: 1px solid var(--border);
      padding: 2rem;
      border-radius: 28px;
      box-shadow: var(--shadow-soft);
      backdrop-filter: blur(12px);
    }

    .insight-card .ic-num {
      font-family: 'Noto Serif KR', serif;
      font-size: 3rem;
      color: rgba(44, 134, 165, 0.12);
      font-weight: 700;
      line-height: 1;
      margin-bottom: 0.5rem;
    }

    .insight-card h4 {
      font-size: 0.92rem;
      color: var(--sea-deep);
      font-weight: 700;
      margin-bottom: 0.6rem;
    }

    .insight-card p {
      font-size: 0.84rem;
      color: var(--muted);
      line-height: 1.82;
    }

    .reflection-box {
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.84), rgba(223, 245, 251, 0.78)),
        url('busan-sea-assets/wave-texture.png') center/cover no-repeat;
      padding: 3rem;
      border-radius: 34px;
      border: 1px solid var(--border);
      box-shadow: var(--shadow);
    }

    .reflection-box h3 {
